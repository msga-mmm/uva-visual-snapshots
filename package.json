{
  "name": "uva-visual-snapshots-workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @uva-visual-snapshots/report-ui && npm run build -w uva-visual-snapshots",
    "dev": "npm run dev -w uva-visual-snapshots",
    "dev:report-ui": "npm run dev -w @uva-visual-snapshots/report-ui",
    "clean": "npm run clean -w uva-visual-snapshots && rimraf packages/report-ui/dist",
    "typecheck": "npm run typecheck -w @uva-visual-snapshots/report-ui && npm run typecheck -w uva-visual-snapshots",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "baseline": "npm run baseline -w uva-visual-snapshots --",
    "report": "npm run build -w @uva-visual-snapshots/report-ui && npm run report -w uva-visual-snapshots --"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@storybook/addon-essentials": "^8.6.12",
    "@storybook/react-vite": "^8.6.12",
    "@types/express": "^5.0.6",
    "@types/node": "^25.4.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "rimraf": "^6.1.3",
    "storybook": "^8.6.12",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.4.1"
  }
}
